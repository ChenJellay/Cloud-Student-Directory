{
  "name": "CMU Student Support Q&A Gateway",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "workspaceFolder": "/workspace",
  "forwardPorts": [8000, 11434],
  "portsAttributes": {
    "8000": {
      "label": "Q&A Gateway API",
      "onAutoForward": "notify"
    },
    "11434": {
      "label": "Ollama",
      "onAutoForward": "silent"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": ["tests"]
      }
    }
  },
  "postCreateCommand": "pip install -r requirements.txt && (ollama serve >/tmp/ollama.log 2>&1 & sleep 2; ollama pull tinyllama || true)",
  "postStartCommand": "pgrep -x ollama >/dev/null || (ollama serve >/tmp/ollama.log 2>&1 &)",
  "remoteUser": "vscode",
  "features": {},
  "containerEnv": {
    "OLLAMA_HOST": "http://127.0.0.1:11434",
    "OLLAMA_MODEL": "tinyllama",
    "LLM_MODE": "auto"
  }
}
